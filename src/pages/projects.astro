---
import Layout from '../layouts/Layout.astro';

const projects = [
	{
		id: 'ai-trading-journal',
		title: 'AI Trading Journal',
		subtitle: 'Machine Learning · Trading Analytics · Automation',
		problem: 'Manual trading journals are inconsistent, lack pattern recognition, and provide no predictive insights. Traders lose valuable data points that could improve performance.',
		solution: 'An AI-powered journaling system that automatically captures trade data, identifies patterns using machine learning, and provides actionable analytics to improve trading decisions.',
		architecture: [
			{ label: 'Backend', value: 'Laravel REST API with WebSocket real-time updates' },
			{ label: 'Frontend', value: 'Next.js dashboard with interactive charts' },
			{ label: 'AI Layer', value: 'OpenAI integration for pattern analysis and NLP insights' },
			{ label: 'Database', value: 'PostgreSQL with time-series optimizations' },
		],
		stack: ['Laravel', 'Next.js', 'OpenAI API', 'PostgreSQL', 'WebSockets', 'TailwindCSS'],
		color: 'var(--color-caramel)',
		featured: true,
	},
	{
		id: 'sap-monitoring-tool',
		title: 'SAP B1 Performance Monitoring',
		subtitle: 'ERP Integration · Real-time Monitoring · Alerting',
		problem: 'SAP Business One environments lack built-in performance monitoring, making it difficult to identify bottlenecks and prevent system degradation.',
		solution: 'A custom monitoring dashboard that connects to SAP B1 Service Layer, tracks key performance metrics, and provides real-time alerting when thresholds are exceeded.',
		architecture: [
			{ label: 'Backend', value: 'ASP.NET Core API with background service workers' },
			{ label: 'Frontend', value: 'React dashboard with real-time WebSocket updates' },
			{ label: 'Integration', value: 'SAP B1 Service Layer REST API' },
			{ label: 'Database', value: 'SQL Server with monitoring data aggregation' },
		],
		stack: ['ASP.NET Core', 'React', 'SAP Service Layer', 'SQL Server', 'SignalR'],
		color: 'var(--color-taupe)',
		featured: false,
	},
	{
		id: 'retail-automation',
		title: 'Retail Automation System',
		subtitle: 'Business Automation · POS Integration · Inventory',
		problem: 'Retail operations involve repetitive manual processes across inventory, point-of-sale, and customer engagement that are error-prone and time-consuming.',
		solution: 'A unified automation platform that streamlines retail workflows from inventory management to customer communication, reducing manual intervention by 80%.',
		architecture: [
			{ label: 'Backend', value: 'Laravel with event-driven architecture' },
			{ label: 'Frontend', value: 'Livewire real-time interface' },
			{ label: 'APIs', value: 'REST APIs for POS and inventory integration' },
			{ label: 'Database', value: 'MySQL with automated reporting pipelines' },
		],
		stack: ['Laravel', 'Livewire', 'MySQL', 'REST APIs', 'TailwindCSS', 'Redis'],
		color: 'var(--color-sienna)',
		featured: false,
	},
	{
		id: 'whatsapp-chatbot',
		title: 'WhatsApp Chatbot Integration',
		subtitle: 'Conversational AI · Business API · Automation',
		problem: 'Businesses struggle to provide instant customer support at scale while maintaining personalized communication through messaging platforms.',
		solution: 'An intelligent WhatsApp chatbot that handles customer inquiries, automates order processing, and escalates complex issues to human agents seamlessly.',
		architecture: [
			{ label: 'Backend', value: 'Laravel with queue-based message processing' },
			{ label: 'Integration', value: 'WhatsApp Business API with webhook handlers' },
			{ label: 'AI Layer', value: 'NLP for intent classification and response generation' },
			{ label: 'Database', value: 'MySQL with conversation state management' },
		],
		stack: ['Laravel', 'WhatsApp Business API', 'OpenAI', 'MySQL', 'Redis', 'Queues'],
		color: 'var(--color-caramel)',
		featured: false,
	},
];
---

<Layout title="Projects — Portfolio" activeNav="PROJECTS">
	<!-- Hero -->
	<section class="hero section-padding">
		<span class="micro-label">PROJECTS</span>
		<h1 class="headline headline--page">
			Systems I've<br />Built
		</h1>
		<p class="body-text">
			Real-world applications solving real business problems. Each project
			demonstrates end-to-end system design from architecture to deployment.
		</p>
	</section>

	<div class="divider"></div>

	<!-- Featured Project (detailed) -->
	{projects.filter(p => p.featured).map((project) => (
		<section class="project-detail section-padding" id={project.id}>
			<div class="project-detail__header">
				<span class="micro-label">{project.subtitle}</span>
				<h2 class="headline headline--section">{project.title}</h2>
			</div>

			<div class="problem-solution">
				<div class="ps-card" style={`background: ${project.color}`}>
					<span class="ps-label">PROBLEM</span>
					<p class="ps-text">{project.problem}</p>
				</div>
				<div class="ps-card ps-card--light">
					<span class="ps-label ps-label--dark">SOLUTION</span>
					<p class="ps-text ps-text--dark">{project.solution}</p>
				</div>
			</div>

			<div class="architecture-grid">
				{project.architecture.map((item) => (
					<div class="arch-item">
						<span class="arch-label">{item.label}</span>
						<p class="arch-value">{item.value}</p>
					</div>
				))}
			</div>

			<div class="project-screenshot">
				<span class="screenshot-placeholder">PROJECT SCREENSHOT</span>
			</div>

			<div class="stack-row">
				{project.stack.map((tech) => (
					<span class="stack-tag">{tech}</span>
				))}
			</div>
		</section>
	))}

	<div class="divider"></div>

	<!-- Other Projects -->
	<section class="other-projects section-padding">
		<span class="micro-label">MORE PROJECTS</span>
		<div class="projects-list">
			{projects.filter(p => !p.featured).map((project, i) => (
				<div class:list={['project-row', { 'project-row--reverse': i % 2 !== 0 }]}>
					<div class="project-row__image" style={`background: ${project.color}`}>
						<span class="screenshot-placeholder">{project.title.toUpperCase()}</span>
					</div>
					<div class="project-row__content">
						<span class="micro-label">{project.subtitle}</span>
						<h3 class="headline headline--card">{project.title}</h3>
						<p class="project-row__desc">{project.problem}</p>
						<div class="stack-row stack-row--sm">
							{project.stack.slice(0, 4).map((tech) => (
								<span class="stack-tag">{tech}</span>
							))}
						</div>
						<a href={`#${project.id}`} class="cta-link">VIEW DETAILS ↗</a>
					</div>
				</div>
			))}
		</div>
	</section>
</Layout>

<style>
	/* ── Hero ── */
	.hero {
		display: flex;
		flex-direction: column;
		gap: 24px;
	}

	/* ── Featured Project Detail ── */
	.project-detail {
		display: flex;
		flex-direction: column;
		gap: 40px;
	}

	.project-detail__header {
		display: flex;
		flex-direction: column;
		gap: 16px;
	}

	/* Problem / Solution cards */
	.problem-solution {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 0;
	}

	.ps-card {
		padding: 40px;
		display: flex;
		flex-direction: column;
		gap: 16px;
	}

	.ps-card--light {
		background: var(--color-surface);
	}

	.ps-label {
		font-family: var(--font-sans);
		font-size: 10px;
		font-weight: 500;
		letter-spacing: 3px;
		color: rgba(255, 255, 255, 0.7);
	}

	.ps-label--dark {
		color: var(--color-tertiary);
	}

	.ps-text {
		font-family: var(--font-sans);
		font-size: 15px;
		line-height: 1.6;
		color: rgba(255, 255, 255, 0.9);
	}

	.ps-text--dark {
		color: var(--color-secondary);
	}

	/* Architecture grid */
	.architecture-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 0;
		border: 1px solid var(--color-divider);
	}

	.arch-item {
		padding: 24px;
		border-right: 1px solid var(--color-divider);
		display: flex;
		flex-direction: column;
		gap: 8px;
	}

	.arch-item:last-child {
		border-right: none;
	}

	.arch-label {
		font-family: var(--font-sans);
		font-size: 10px;
		font-weight: 500;
		letter-spacing: 2px;
		color: var(--color-tertiary);
		text-transform: uppercase;
	}

	.arch-value {
		font-family: var(--font-sans);
		font-size: 13px;
		color: var(--color-secondary);
		line-height: 1.5;
	}

	/* Screenshot placeholder */
	.project-screenshot {
		background: var(--color-surface);
		height: 320px;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.screenshot-placeholder {
		font-family: var(--font-mono);
		font-size: 14px;
		font-weight: 200;
		letter-spacing: 3px;
		color: var(--color-tertiary);
	}

	/* Stack tags row */
	.stack-row {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}

	.stack-tag {
		font-size: 10px;
		font-weight: 500;
		letter-spacing: 1px;
		text-transform: uppercase;
		padding: 6px 14px;
		background: var(--color-text);
		color: #fff;
	}

	/* ── Other Projects ── */
	.other-projects {
		display: flex;
		flex-direction: column;
		gap: 32px;
	}

	.projects-list {
		display: flex;
		flex-direction: column;
		gap: 0;
	}

	.project-row {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 0;
		border-bottom: 1px solid var(--color-divider);
	}

	.project-row:last-child {
		border-bottom: none;
	}

	.project-row--reverse {
		direction: rtl;
	}

	.project-row--reverse > * {
		direction: ltr;
	}

	.project-row__image {
		min-height: 280px;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.project-row__image .screenshot-placeholder {
		color: rgba(255, 255, 255, 0.7);
	}

	.project-row__content {
		display: flex;
		flex-direction: column;
		gap: 16px;
		padding: 40px;
		justify-content: center;
	}

	.project-row__desc {
		font-size: 13px;
		color: var(--color-secondary);
		line-height: 1.6;
	}

	.stack-row--sm .stack-tag {
		font-size: 9px;
		padding: 4px 10px;
	}

	/* ── Responsive ── */
	@media (max-width: 1024px) {
		.architecture-grid {
			grid-template-columns: repeat(2, 1fr);
		}

		.arch-item:nth-child(2) {
			border-right: none;
		}

		.arch-item:nth-child(3),
		.arch-item:nth-child(4) {
			border-top: 1px solid var(--color-divider);
		}
	}

	@media (max-width: 768px) {
		.problem-solution,
		.project-row {
			grid-template-columns: 1fr;
		}

		.project-row--reverse {
			direction: ltr;
		}

		.architecture-grid {
			grid-template-columns: 1fr;
		}

		.arch-item {
			border-right: none;
			border-bottom: 1px solid var(--color-divider);
		}

		.arch-item:last-child {
			border-bottom: none;
		}
	}
</style>
