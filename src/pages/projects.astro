---
import Layout from '../layouts/Layout.astro';

const projects = [
	{
		id: 'plant-maintenance-management-system',
		title: 'Plant Maintenance Management System',
		subtitle: 'Industrial Operations · Maintenance Planning · Fixed Assets',
		problem: 'Industrial teams often manage plant equipment, maintenance schedules, and fixed asset records across disconnected tools, which creates delays, weak traceability, and poor visibility into asset performance.',
		solution: 'A centralized maintenance and fixed asset platform that helps teams manage plants and equipment, convert service needs into work orders, track execution through completion, and monitor asset activity from acquisition to depreciation.',
		architecture: [
			{ label: 'Backend', value: 'Laravel application with workflow-driven maintenance modules' },
			{ label: 'Frontend', value: 'Operational dashboard for plants, work orders, and asset records' },
			{ label: 'Workflows', value: 'Service requests, work order conversion, assignment, and completion tracking' },
			{ label: 'Database', value: 'Centralized asset and maintenance history for lifecycle reporting' },
		],
		stack: ['Laravel', 'Livewire', 'MySQL', 'Asset Tracking', 'Work Orders', 'TailwindCSS'],
		color: 'var(--color-caramel)',
		featured: true,
	},
	{
		id: 'legal-case-management-system',
		title: 'Legal Case Management System',
		subtitle: 'Law Firm Operations · Case Tracking · Secure Access',
		problem: 'Law firms often manage cases, clients, documents, schedules, and billing across separate systems, which slows down daily work and limits visibility into team workload, revenue, and performance.',
		solution: 'A role-based legal case management platform that centralizes case tracking, client records, document workflows, scheduling, billing, and reporting in one dashboard, with secure authentication and two-factor authentication support for legal teams.',
		architecture: [
			{ label: 'Access', value: 'Role-based permissions with secure authentication and 2FA support' },
			{ label: 'Operations', value: 'Unified dashboard for cases, clients, schedules, and daily legal workflows' },
			{ label: 'Documents', value: 'Centralized document handling and case-related workflow tracking' },
			{ label: 'Reporting', value: 'Billing, revenue, workload, and performance visibility in one system' },
		],
		stack: ['Role-Based Access', '2FA', 'Case Tracking', 'Document Workflows', 'Billing', 'Reporting'],
		color: 'var(--color-taupe)',
		featured: false,
	},
	{
		id: 'retail-automation',
		title: 'Retail Automation System',
		subtitle: 'Business Automation · POS Integration · Inventory',
		problem: 'Retail operations involve repetitive manual processes across inventory, point-of-sale, and customer engagement that are error-prone and time-consuming.',
		solution: 'A unified automation platform that streamlines retail workflows from inventory management to customer communication, reducing manual intervention by 80%.',
		architecture: [
			{ label: 'Backend', value: 'Laravel with event-driven architecture' },
			{ label: 'Frontend', value: 'Livewire real-time interface' },
			{ label: 'APIs', value: 'REST APIs for POS and inventory integration' },
			{ label: 'Database', value: 'MySQL with automated reporting pipelines' },
		],
		stack: ['Laravel', 'Livewire', 'MySQL', 'REST APIs', 'TailwindCSS', 'Redis'],
		color: 'var(--color-sienna)',
		featured: false,
	},
	{
		id: 'procurement-purchase-to-pay-platform',
		title: 'Procurement & Purchase-to-Pay Platform',
		subtitle: 'Procurement Operations · Approvals · Auditability',
		problem: 'Businesses relying on spreadsheets and email for purchasing struggle with slow approvals, poor traceability, fragmented coordination, and limited visibility across procurement, logistics, and finance.',
		solution: 'A role-based procurement and purchase-to-pay platform that manages the full lifecycle from purchase requests and multi-level approvals to purchase orders, goods receipt, border-clearance tracking, invoice processing, and finance settlement in a single auditable workflow.',
		architecture: [
			{ label: 'Backend', value: 'Laravel services managing requisitions, approvals, orders, receipts, and settlement workflows' },
			{ label: 'Frontend', value: 'Inertia and React dashboards for procurement, logistics, finance, and admin teams' },
			{ label: 'Governance', value: 'Policy-based access control, master data management, and end-to-end audit logging' },
			{ label: 'Operations', value: 'Imported shipment tracking, invoice processing, and cross-functional workflow visibility' },
		],
		stack: ['Laravel', 'Inertia', 'React', 'Policy-Based Access', 'Audit Logging', 'P2P Workflows'],
		color: 'var(--color-caramel)',
		featured: false,
	},
];
---

<Layout title="Projects — Portfolio" activeNav="PROJECTS">
	<!-- Hero -->
	<section class="hero section-padding" data-aos="fade-up">
		<span class="micro-label">PROJECTS</span>
		<h1 class="headline headline--page">
			Systems I've<br />Built
		</h1>
		<p class="body-text">
			Real-world applications solving real business problems. Each project
			demonstrates end-to-end system design from architecture to deployment.
		</p>
	</section>

	<div class="divider"></div>

	<!-- Featured Project (detailed) -->
	{projects.filter(p => p.featured).map((project) => (
		<section class="project-detail section-padding" id={project.id}>
			<div class="project-detail__header">
				<span class="micro-label">{project.subtitle}</span>
				<h2 class="headline headline--section">{project.title}</h2>
			</div>

			<div class="problem-solution">
				<div class="ps-card" style={`background: ${project.color}`} data-aos="fade-right">
					<span class="ps-label">PROBLEM</span>
					<p class="ps-text">{project.problem}</p>
				</div>
				<div class="ps-card ps-card--light" data-aos="fade-left">
					<span class="ps-label ps-label--dark">SOLUTION</span>
					<p class="ps-text ps-text--dark">{project.solution}</p>
				</div>
			</div>

			<div class="architecture-grid" data-aos="fade-up">
				{project.architecture.map((item) => (
					<div class="arch-item">
						<span class="arch-label">{item.label}</span>
						<p class="arch-value">{item.value}</p>
					</div>
				))}
			</div>

			<div class="stack-row" data-aos="fade-up">
				{project.stack.map((tech) => (
					<span class="stack-tag">{tech}</span>
				))}
			</div>
		</section>
	))}

	<div class="divider"></div>

	<!-- Other Projects -->
	<section class="other-projects section-padding">
		<span class="micro-label">MORE PROJECTS</span>
		<div class="projects-list">
			{projects.filter(p => !p.featured).map((project, i) => (
				<div class:list={['project-row', { 'project-row--reverse': i % 2 !== 0 }]} data-aos="fade-up" data-aos-delay={i * 100}>
					<div class="project-row__image" style={`background: ${project.color}`}>
						<span class="screenshot-placeholder">{project.title.toUpperCase()}</span>
					</div>
					<div class="project-row__content">
						<span class="micro-label">{project.subtitle}</span>
						<h3 class="headline headline--card">{project.title}</h3>
						<p class="project-row__desc">{project.problem}</p>
						<div class="stack-row stack-row--sm">
							{project.stack.slice(0, 4).map((tech) => (
								<span class="stack-tag">{tech}</span>
							))}
						</div>
						<a href={`#${project.id}`} class="cta-link">VIEW DETAILS ↗</a>
					</div>
				</div>
			))}
		</div>
	</section>
</Layout>

<style>
	/* ── Hero ── */
	.hero {
		display: flex;
		flex-direction: column;
		gap: 24px;
	}

	/* ── Featured Project Detail ── */
	.project-detail {
		display: flex;
		flex-direction: column;
		gap: 40px;
	}

	.project-detail__header {
		display: flex;
		flex-direction: column;
		gap: 16px;
	}

	/* Problem / Solution cards */
	.problem-solution {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 0;
	}

	.ps-card {
		padding: 40px;
		display: flex;
		flex-direction: column;
		gap: 16px;
	}

	.ps-card--light {
		background: var(--color-surface);
	}

	.ps-label {
		font-family: var(--font-sans);
		font-size: 10px;
		font-weight: 500;
		letter-spacing: 3px;
		color: rgba(255, 255, 255, 0.7);
	}

	.ps-label--dark {
		color: var(--color-tertiary);
	}

	.ps-text {
		font-family: var(--font-sans);
		font-size: 15px;
		line-height: 1.6;
		color: rgba(255, 255, 255, 0.9);
	}

	.ps-text--dark {
		color: var(--color-secondary);
	}

	/* Architecture grid */
	.architecture-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 0;
		border: 1px solid var(--color-divider);
	}

	.arch-item {
		padding: 24px;
		border-right: 1px solid var(--color-divider);
		display: flex;
		flex-direction: column;
		gap: 8px;
		transition: background 0.2s ease;
	}

	.arch-item:hover {
		background: var(--color-surface);
	}

	.arch-item:last-child {
		border-right: none;
	}

	.arch-label {
		font-family: var(--font-sans);
		font-size: 10px;
		font-weight: 500;
		letter-spacing: 2px;
		color: var(--color-tertiary);
		text-transform: uppercase;
	}

	.arch-value {
		font-family: var(--font-sans);
		font-size: 13px;
		color: var(--color-secondary);
		line-height: 1.5;
	}

	.screenshot-placeholder {
		font-family: var(--font-mono);
		font-size: 14px;
		font-weight: 200;
		letter-spacing: 3px;
		color: var(--color-tertiary);
	}

	/* Stack tags row */
	.stack-row {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}

	.stack-tag {
		font-size: 10px;
		font-weight: 500;
		letter-spacing: 1px;
		text-transform: uppercase;
		padding: 6px 14px;
		background: var(--color-text);
		color: #fff;
		transition: transform 0.2s ease, background 0.2s ease;
	}

	.stack-tag:hover {
		transform: translateY(-2px);
		background: var(--color-sienna);
	}

	/* ── Other Projects ── */
	.other-projects {
		display: flex;
		flex-direction: column;
		gap: 32px;
	}

	.projects-list {
		display: flex;
		flex-direction: column;
		gap: 0;
	}

	.project-row {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 0;
		border-bottom: 1px solid var(--color-divider);
		transition: background 0.3s ease;
	}

	.project-row:hover {
		background: var(--color-surface);
	}

	.project-row:last-child {
		border-bottom: none;
	}

	.project-row--reverse {
		direction: rtl;
	}

	.project-row--reverse > * {
		direction: ltr;
	}

	.project-row__image {
		min-height: 280px;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.project-row__image .screenshot-placeholder {
		color: rgba(255, 255, 255, 0.7);
	}

	.project-row__content {
		display: flex;
		flex-direction: column;
		gap: 16px;
		padding: 40px;
		justify-content: center;
		transition: transform 0.3s ease;
	}

	.project-row:hover .project-row__content {
		transform: translateX(8px);
	}

	.project-row__desc {
		font-size: 13px;
		color: var(--color-secondary);
		line-height: 1.6;
	}

	.stack-row--sm .stack-tag {
		font-size: 9px;
		padding: 4px 10px;
	}

	/* ── Responsive ── */
	@media (max-width: 1024px) {
		.architecture-grid {
			grid-template-columns: repeat(2, 1fr);
		}

		.arch-item:nth-child(2) {
			border-right: none;
		}

		.arch-item:nth-child(3),
		.arch-item:nth-child(4) {
			border-top: 1px solid var(--color-divider);
		}
	}

	@media (max-width: 768px) {
		.problem-solution,
		.project-row {
			grid-template-columns: 1fr;
		}

		.project-row--reverse {
			direction: ltr;
		}

		.architecture-grid {
			grid-template-columns: 1fr;
		}

		.arch-item {
			border-right: none;
			border-bottom: 1px solid var(--color-divider);
		}

		.arch-item:last-child {
			border-bottom: none;
		}
	}
</style>
