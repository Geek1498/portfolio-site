---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title?: string;
	description?: string;
	activeNav?: string;
}

const {
	title = 'Portfolio — Full-Stack Developer',
	description = 'Full-Stack Developer specializing in Laravel, Next.js, AI Systems, and Business Automation.',
	activeNav = '',
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
		<link rel="icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />

		<!-- Geist & Geist Mono fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Geist+Mono:wght@200;400;500;700&family=Geist:wght@400;500;700&display=swap"
			rel="stylesheet"
		/>

		<!-- AOS (Animate On Scroll) -->
		<link rel="stylesheet" href="https://unpkg.com/aos@2.3.4/dist/aos.css" />

		<title>{title}</title>
	</head>
	<body>
		<Navbar active={activeNav} />
		<main>
			<slot />
		</main>
		<Footer />

		<script is:inline src="https://unpkg.com/aos@2.3.4/dist/aos.js"></script>
		<script is:inline>
			document.addEventListener('DOMContentLoaded', () => {
				AOS.init({
					duration: 600,
					easing: 'ease-out-cubic',
					once: true,
					offset: 80,
				});
			});
		</script>
	</body>
</html>

<style is:global>
	/* ── Reset ── */
	*,
	*::before,
	*::after {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}

	/* ── Design tokens ── */
	:root {
		--color-bg: #e8e9eb;
		--color-text: #1a1a1a;
		--color-body: #4a4a4a;
		--color-secondary: #666666;
		--color-tertiary: #5f5f5f;
		--color-divider: #c4c4c4;
		--color-surface: #f5f5f5;
		--color-caramel: #c2956a;
		--color-taupe: #a38979;
		--color-sienna: #8f5a3c;
		--font-mono: 'Geist Mono', monospace;
		--font-sans: 'Geist', sans-serif;
		--page-padding: 80px;
		--max-width: 1440px;
	}

	html {
		font-size: 16px;
		-webkit-font-smoothing: antialiased;
		-moz-osx-font-smoothing: grayscale;
	}

	body {
		font-family: var(--font-sans);
		background: var(--color-bg);
		color: var(--color-text);
		line-height: 1.6;
	}

	img {
		max-width: 100%;
		display: block;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	/* ── Utility classes ── */
	.section-padding {
		padding: 64px var(--page-padding);
	}

	.micro-label {
		font-family: var(--font-sans);
		font-size: 10px;
		font-weight: 400;
		letter-spacing: 3px;
		color: var(--color-tertiary);
		text-transform: uppercase;
	}

	.headline {
		font-family: var(--font-mono);
		font-weight: 200;
		color: var(--color-text);
		line-height: 0.95;
	}

	.headline--hero {
		font-size: clamp(48px, 6vw, 88px);
	}

	.headline--page {
		font-size: clamp(40px, 5vw, 72px);
	}

	.headline--section {
		font-size: clamp(28px, 3vw, 40px);
	}

	.headline--card {
		font-size: clamp(20px, 2vw, 24px);
		line-height: 1.2;
	}

	.body-text {
		font-family: var(--font-sans);
		font-size: 16px;
		font-weight: 400;
		color: var(--color-body);
		line-height: 1.6;
		max-width: 600px;
	}

	.cta-link {
		font-family: var(--font-sans);
		font-size: 12px;
		font-weight: 500;
		letter-spacing: 1px;
		text-decoration: none;
		color: var(--color-text);
		cursor: pointer;
		background: none;
		border: none;
		text-transform: uppercase;
		position: relative;
		display: inline-block;
	}

	.cta-link::after {
		content: '';
		position: absolute;
		bottom: -2px;
		left: 0;
		width: 0;
		height: 1px;
		background: currentColor;
		transition: width 0.3s ease;
	}

	.cta-link:hover::after {
		width: 100%;
	}

	/* ── Card hover utility ── */
	.card-hover {
		transition: transform 0.3s ease, box-shadow 0.3s ease;
	}

	.card-hover:hover {
		transform: translateY(-4px);
		box-shadow: 0 12px 32px rgba(0, 0, 0, 0.1);
	}

	/* ── Reduced motion ── */
	@media (prefers-reduced-motion: reduce) {
		*,
		*::before,
		*::after {
			animation-duration: 0.01ms !important;
			animation-iteration-count: 1 !important;
			transition-duration: 0.01ms !important;
		}

		.card-hover:hover {
			transform: none;
		}
	}

	.divider {
		width: 100%;
		height: 1px;
		background: var(--color-divider);
	}

	/* ── Responsive ── */
	@media (max-width: 1024px) {
		:root {
			--page-padding: 40px;
		}
	}

	@media (max-width: 640px) {
		:root {
			--page-padding: 20px;
		}
	}
</style>
